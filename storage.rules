rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid
                         && request.resource.size < 10 * 1024 * 1024;
      allow read: if request.auth != null && request.auth.uid == uid;
    }
  }
}
